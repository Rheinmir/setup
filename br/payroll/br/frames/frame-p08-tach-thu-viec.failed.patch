+"""p08_thuviec — tách ngày công giai đoạn thử việc / sau thử việc theo
+'Ngày kết thúc thử việc' (C5.1.1), gồm cả ngày nghỉ hưởng lương của từng
+giai đoạn — nền tính lương 85%/100%.
+"""
+
+from app.p01_lichky import sinh_lich_ky
+from app.p06_workday import cong_tho, ho_so
+from app.p07_kyhieu import phan_loai
+
+
+def tach_thu_viec(msnv, thang):
+    nv = ho_so(msnv)
+    moc = nv.get("ngay_ket_thuc_thu_viec") or ""
+
+    ban_ghi = {r["ngay"]: r["ky_hieu"] for r in cong_tho(thang) if r["msnv"] == msnv}
+
+    ngay_tv = {"lam_viec": 0}
+    ngay_sau_tv = {"lam_viec": 0}
+
+    for ngay in sinh_lich_ky(thang)["ngay"]:
+        iso = ngay["ngay"]
+        if iso in ban_ghi:
+            huong_luong = phan_loai(ban_ghi[iso]).get("huong_luong")
+        else:
+            huong_luong = not ngay["le"]
+
+        if not huong_luong:
+            continue
+
+        giai_doan = ngay_tv if (moc and iso < moc) else ngay_sau_tv
+        giai_doan["lam_viec"] += 1
+
+    return {"ngay_tv": ngay_tv, "ngay_sau_tv": ngay_sau_tv}
