{
  "permissions": {
    "deny": [
      "Write(./raw/**)",
      "Edit(./raw/**)",
      "MultiEdit(./raw/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/user_prompt_submit.py\" ]; then python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/user_prompt_submit.py\"; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool_use.py\" ]; then python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool_use.py\"; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/orca_guard.py\" ]; then python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/orca_guard.py\"; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_use.py\" ]; then python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_use.py\"; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop.py\" ]; then python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop.py\"; fi"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_end.py\" ]; then python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_end.py\"; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_start.py\" ]; then python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_start.py\"; fi"
          }
        ]
      }
    ]
  }
}